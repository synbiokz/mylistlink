# Database (choose one)
# - Supabase pooled (recommended for runtime):
# DATABASE_URL="postgresql://postgres:<username>@<host>:6543/postgres?pgbouncer=true&connection_limit=1&connect_timeout=10"
# DIRECT_URL="postgresql://postgres:<username>@<host>:5432/postgres?sslmode=require"
# - OR local SQLite for offline dev:
# DATABASE_URL="file:./apps/web/prisma/dev.db"

# External APIs
OMDB_API_KEY="your-omdb-key"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me"
AUTH_SECRET="change-me"

# Email (magic link) — production SMTP
#EMAIL_SERVER_HOST="smtp.yourhost.com"
#EMAIL_SERVER_PORT="587"
#EMAIL_SERVER_USER="smtp-user"
#EMAIL_SERVER_PASSWORD="smtp-pass"
EMAIL_FROM="ListLink <no-reply@localhost>"

# OAuth Providers (optional)
#GOOGLE_CLIENT_ID=""
#GOOGLE_CLIENT_SECRET=""
#GITHUB_CLIENT_ID=""
#GITHUB_CLIENT_SECRET=""

# Enable dev credentials login (optional)
#DEV_CREDENTIALS_LOGIN=true