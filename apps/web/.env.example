# Supabase (recommended runtime connection — PgBouncer pool)
DATABASE_URL="postgresql://postgres:<username>@<host>:6543/postgres?pgbouncer=true&connection_limit=1&connect_timeout=10"

# Supabase (migrations connection — direct/session)
DIRECT_URL="postgresql://postgres:<username>@<host>:5432/postgres?sslmode=require"

# External APIs
OMDB_API_KEY="your-omdb-key"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me"
AUTH_SECRET="change-me"

# Notes
# - Copy this file to `.env` (for Prisma CLI) and to `.env.local` (for Next.js runtime) with real values.
# - Do NOT commit `.env` or `.env.local`.
# - If your password contains special characters, ensure they are URL-encoded in the connection string.
